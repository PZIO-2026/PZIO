# Backend configuration. Copy to `.env` and fill in real values for non-default
# settings. Never commit the real `.env` file.

# Database
# Local default uses SQLite. Production target is PostgreSQL (CON4 in the SRS):
#   DATABASE_URL=postgresql+psycopg://user:password@host:5432/pzio
DATABASE_URL=sqlite:///./pzio.db

# JWT
# JWT_SECRET MUST be overridden in production with a long random value.
JWT_SECRET=dev-secret-change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRES_MIN=60

# CORS — comma-separated list of allowed origins (frontend dev server, etc.).
CORS_ORIGINS=http://localhost:5173

# Directory for forced DB backups (SAD §4.5 — POST /api/admin/backups).
BACKUP_DIR=./backups
